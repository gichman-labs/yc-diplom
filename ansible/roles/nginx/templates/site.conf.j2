server {
    listen {{ nginx_listen_port }};
    listen [::]:{{ nginx_listen_port }};

    server_name _;

    root {{ nginx_site_root }};
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    location = /basic_status {
        stub_status;
        allow 127.0.0.1;
        allow ::1;
        allow 10.10.10.30;
        deny all;
    }
}
